// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  profilePhoto String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  trips        Trip[]
}

model Trip {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  startDate      DateTime
  endDate        DateTime
  description    String?
  coverPhoto     String?
  isPublic       Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  stops          Stop[]
  checklistItems ChecklistItem[]
  notes          Note[]
}

model Stop {
  id            String     @id @default(cuid())
  tripId        String
  trip          Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city          String
  country       String
  arrivalDate   DateTime
  departureDate DateTime
  orderIndex    Int
  activities    Activity[]
  notes         Note[]
}

model Activity {
  id          String   @id @default(cuid())
  stopId      String
  stop        Stop     @relation(fields: [stopId], references: [id], onDelete: Cascade)
  name        String
  type        String // e.g., "Food", "Sightseeing", "Adventure"
  cost        Float    @default(0)
  duration    String? // e.g., "2 hours", "Half day"
  description String?
}

model ChecklistItem {
  id       String  @id @default(cuid())
  tripId   String
  trip     Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category String // e.g., "Clothing", "Documents"
  name     String
  isPacked Boolean @default(false)
}

model Note {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stopId    String? // Optional: tied to a specific stop
  stop      Stop?    @relation(fields: [stopId], references: [id], onDelete: SetNull)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
